# Photo2Print — הגדרות סביבה (העתק ל-.env ומלא ערכים)

# --- כללי ---
P2P_DATA_DIR=./data
P2P_DB_URL=sqlite:///./data/photo2print.db
P2P_MAX_UPLOAD_MB=200
P2P_MAX_IMAGE_MB=20

# --- ספק יצירת Mesh (tripo | meshy | local_extrude) ---
# local_extrude עובד בלי מפתח API — מחלץ צללית מהתמונה ומכין מודל אקסטרוזיה.
# ל-AI מלא (image-to-3D) יש להזין מפתח Tripo3D או Meshy.
P2P_MESH_PROVIDER=local_extrude
P2P_MESH_FALLBACK_PROVIDER=
TRIPO_API_KEY=
MESHY_API_KEY=

# --- Slicer ---
# נתיב ל-prusa-slicer-console.exe (אם ריק — חיפוש אוטומטי ב-tools/ ובנתיבי התקנה נפוצים)
P2P_SLICER_PATH=

# --- Timeouts (שניות) ---
P2P_CLOUD_TIMEOUT=240
P2P_SLICE_TIMEOUT=120

# --- עלויות ---
P2P_FILAMENT_PRICE_PER_KG=90
P2P_ELECTRICITY_PRICE_PER_KWH=0.64
P2P_PRINTER_WATTS=120
